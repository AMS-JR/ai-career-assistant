OPENAI_API_KEY=your_api_key_here
# Used by all career-assistant agents (first non-empty wins): OPENAI_CAREER_MODEL, OPENAI_DEFAULT_MODEL, OPENAI_MODEL
OPENAI_DEFAULT_MODEL=gpt-5-nano

# Fast job list (no matcher LLMs): HTTP + keyword ranking only, Remotive+Arbeitnow in parallel. Huge latency win.
# DIRECT_JOB_FETCH_ONLY=false

# Fewer Arbeitnow pages when using direct/fallback fetch (default 3).
# ARBEITNOW_FALLBACK_MAX_PAGES=3

# Optional output caps (can speed up parser/tailor; unset = model default).
# RESUME_PARSER_MAX_OUTPUT_TOKENS=6144
# RESUME_TAILOR_MAX_OUTPUT_TOKENS=4096

# LLM turns: role-specific defaults are faster than one huge global cap.
# Resume parser (no tools): RESUME_PARSER_MAX_TURNS=3
# Board matchers (tools): MATCHER_MAX_TURNS=14  (falls back to AGENT_MAX_TURNS if unset)
# Job dedupe LLM (no tools): JOB_AGGREGATOR_MAX_TURNS=3
# Tailor (no tools): RESUME_TAILOR_MAX_TURNS=6
# Legacy override still read by matchers/tailor when MATCHER_MAX_TURNS / RESUME_TAILOR_MAX_TURNS omitted:
# AGENT_MAX_TURNS=30

# Skip the final dedupe/rank LLM — same ordering as score sort + URL dedupe (much faster, slightly less fuzzy dedupe).
# SKIP_JOB_AGGREGATOR_LLM=false

# Fewer HTTP rounds when fixing Remotive URLs after the agent (default 2; max 4).
# REMOTIVE_RECONCILE_QUERY_CAP=2

# Parsed resume: `local` = Gradio session state only (default).
# `openai_vector_store` = reserved for RAG; set OPENAI_VECTOR_STORE_ID when implemented.
PROFILE_BACKEND=local
# PROFILE_BACKEND=openai_vector_store
# OPENAI_VECTOR_STORE_ID=

# Performance / job APIs
# JOB_HTTP_TIMEOUT_SECONDS=15
# JOB_API_CACHE_TTL_SECONDS=300
# Drop job rows older than N days when posted date is known (Arbeitnow: created_at unix; Remotive: publication_date). 0 = no filter
# JOB_LISTING_MAX_AGE_DAYS=90
# If keyword overlap filter removes every job, show the unfiltered matcher list instead of an empty UI
# RELAX_PROFILE_KEYWORD_JOB_FILTER=false
# Set to 0 to disable response caching for Arbeitnow/Remotive.
# AGGREGATOR_MAX_JOBS=40
# AGGREGATOR_DESCRIPTION_MAX_CHARS=400

# LLM context limits (avoid context_length_exceeded on smaller models)
# RESUME_PARSE_MAX_INPUT_CHARS=24000
# JOB_TOOL_MAX_RESULTS=20
# JOB_TOOL_DESCRIPTION_MAX_CHARS=800
# MATCHER_PROFILE_JSON_MAX_CHARS=14000
# Matcher LLM filter (lower if you get zero jobs; both boards have software listings)
# MATCHER_MIN_SKILL_PERCENT=50
# MATCHER_MIN_OVERALL_SCORE=50
# TAILOR_PROFILE_JSON_MAX_CHARS=18000
# TAILOR_JOB_DESCRIPTION_MAX_CHARS=2500

# Logging: DEBUG, INFO, WARNING, ERROR
# LOG_LEVEL=INFO